    if descendant:IsA("Sound") then
        task.wait(0.1)
        
        descendant:GetPropertyChangedSignal("SoundId"):Connect(function()
            processSound(descendant)
        end)
        
        descendant:GetPropertyChangedSignal("Playing"):Connect(function()
            if descendant.Playing then
                task.wait(0.02)
                processSound(descendant)
            end
        end)
        
        knownSounds[descendant] = true
    end
end)

-- Periodic check
task.spawn(function()
