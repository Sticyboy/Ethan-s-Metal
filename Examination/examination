-- ============================================================
--  NPC/PLAYER HIGHLIGHTER WITH HEALTH BARS & AIMBOT
--  - Red highlight for NPCs (workspace.Characters)
--  - Green highlight for other players
--  - Names above characters
--  - Health bars using Humanoid.Attributes.Health
--  - Aimbot (hold right click to aim at closest NPC ONLY)
--  - Wall check
-- ============================================================

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Highlighter",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Highlight NPCs & Players with Health",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "Highlighter",
        FileName = "Settings"
    },
    Discord = { Enabled = false },
    KeySystem = false,
})

local MainTab = Window:CreateTab("Main", "user")

-- ===== SERVICES =====
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local Camera = Workspace.CurrentCamera
local lp = Players.LocalPlayer

-- ===== STATE =====
local highlightingEnabled = false
local aimbotEnabled = false
local wallCheckEnabled = true
local highlightData = {}  -- [character] = {highlight, billboard, healthBar, healthText, healthConnection, healthSource, isPlayer}
local scanConnection = nil
local cleanupConnection = nil
local aimbotConnection = nil

-- Aimbot Settings
local aimbotFOV = 200
local aimbotSmoothness = 0.7

-- ===== FIND CHARACTERS FOLDER =====
local function getCharactersFolder()
    local chars = Workspace:FindFirstChild("Characters")
    if chars then return chars end
    
    local playersFolder = Workspace:FindFirstChild("Players")
    if playersFolder then
        local survivors = playersFolder:FindFirstChild("Survivors")
        if survivors then return survivors end
        local killers = playersFolder:FindFirstChild("Killers")
        if killers then return killers end
        return playersFolder
    end
    
    return Workspace
end

-- ===== CHECK IF CHARACTER IS LOCAL PLAYER =====
local function isLocalPlayerCharacter(character)
    if not character then return false end
    local char = lp.Character
    if not char then return false end
    return character == char
end

-- ===== CHECK IF CHARACTER IS A PLAYER =====
local function isPlayerCharacter(character)
    if not character then return false end
    if isLocalPlayerCharacter(character) then return true end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character == character then
            return true
        end
    end
    return false
end

-- ===== CHECK IF CHARACTER IS AN NPC =====
local function isNPC(character)
    if not character then return false end
    if isLocalPlayerCharacter(character) then return false end
    return not isPlayerCharacter(character)
end

-- ===== CHECK IF CHARACTER IS ALIVE =====
local function isCharacterAlive(character)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local health = humanoid:GetAttribute("Health") or humanoid.Health
        return health and health > 0
    end
    return true
end

-- ===== GET HEALTH VALUES =====
local function getHealthValues(character)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil, nil end
    
    local currentHealth = humanoid:GetAttribute("Health") or humanoid.Health
    local maxHealth = humanoid:GetAttribute("MaxHealth") or humanoid.MaxHealth or 100
    
    return currentHealth, maxHealth
end

-- ===== WALL CHECK =====
local function wallCheck(targetPosition, targetCharacter)
    if not wallCheckEnabled then return false end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPosition - origin).Unit
    
    local raycastParams = RaycastParams.new()
    local blacklist = {lp.Character, Camera}
    
    if targetCharacter then
        table.insert(blacklist, targetCharacter)
        for _, descendant in ipairs(targetCharacter:GetDescendants()) do
            if descendant:IsA("BasePart") or descendant:IsA("Accessory") or descendant:IsA("Model") then
                table.insert(blacklist, descendant)
            end
        end
    end
    
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = blacklist
    
    local raycastResult = Workspace:Raycast(origin, direction * 1000, raycastParams)
    
    if raycastResult then
        local distanceToTarget = (targetPosition - origin).Magnitude
        local distanceToHit = (raycastResult.Position - origin).Magnitude
        return distanceToHit < distanceToTarget - 1
    end
    
    return false
end

-- ===== REMOVE HIGHLIGHT FROM CHARACTER =====
local function removeHighlight(character)
    local data = highlightData[character]
    if data then
        if data.highlight then
            pcall(function() data.highlight:Destroy() end)
        end
        if data.billboard then
            pcall(function() data.billboard:Destroy() end)
        end
        if data.healthConnection then
            pcall(function() 
                if type(data.healthConnection) == "table" then
                    for _, conn in ipairs(data.healthConnection) do
                        conn:Disconnect()
                    end
                else
                    data.healthConnection:Disconnect()
                end
            end)
        end
        highlightData[character] = nil
    end
end

-- ===== CREATE NAME BILLBOARD WITH HEALTH =====
local function createNameBillboard(character, name, color)
    local attachment = character:FindFirstChild("Head") or 
                       character:FindFirstChild("HumanoidRootPart") or 
                       character:FindFirstChild("Torso") or
                       character.PrimaryPart
    
    if not attachment then return nil, nil, nil, nil end
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameBillboard"
    billboard.Adornee = attachment
    billboard.Size = UDim2.new(0, 200, 0, 75)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = attachment
    
    -- Name Label
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0, 30)
    nameLabel.Position = UDim2.new(0, 0, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = name
    nameLabel.TextColor3 = color
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = billboard
    
    -- Health bar container
    local healthContainer = Instance.new("Frame")
    healthContainer.Size = UDim2.new(1, -20, 0, 20)
    healthContainer.Position = UDim2.new(0, 10, 0, 32)
    healthContainer.BackgroundColor3 = Color3.new(0, 0, 0)
    healthContainer.BorderSizePixel = 1
    healthContainer.BorderColor3 = Color3.new(1, 1, 1)
    healthContainer.Parent = billboard
    
    -- Health bar fill
    local healthBar = Instance.new("Frame")
    healthBar.Size = UDim2.new(1, 0, 1, 0)
    healthBar.BackgroundColor3 = Color3.new(0, 1, 0)
    healthBar.BorderSizePixel = 0
    healthBar.Parent = healthContainer
    
    -- Health text
    local healthText = Instance.new("TextLabel")
    healthText.Size = UDim2.new(1, 0, 1, 0)
    healthText.BackgroundTransparency = 1
    healthText.TextScaled = true
    healthText.Font = Enum.Font.GothamMedium
    healthText.TextColor3 = Color3.new(1, 1, 1)
    healthText.TextStrokeTransparency = 0
    healthText.TextStrokeColor3 = Color3.new(0, 0, 0)
    healthText.Parent = healthContainer
    
    return billboard, healthBar, healthText, healthContainer
end

-- ===== UPDATE HEALTH BAR =====
local function updateHealthBar(character)
    local data = highlightData[character]
    if not data then return end
    
    local currentHealth, maxHealth = getHealthValues(character)
    if not currentHealth or not maxHealth then return end
    
    local healthPercentage = math.clamp(currentHealth / maxHealth, 0, 1)
    
    if data.healthBar then
        data.healthBar.Size = UDim2.new(healthPercentage, 0, 1, 0)
        
        if healthPercentage > 0.6 then
            data.healthBar.BackgroundColor3 = Color3.new(0, 1, 0)
        elseif healthPercentage > 0.3 then
            data.healthBar.BackgroundColor3 = Color3.new(1, 1, 0)
        else
            data.healthBar.BackgroundColor3 = Color3.new(1, 0, 0)
        end
    end
    
    if data.healthText then
        data.healthText.Text = math.floor(currentHealth) .. "/" .. math.floor(maxHealth)
    end
    
    if currentHealth <= 0 then
        removeHighlight(character)
    end
end

-- ===== HIGHLIGHT CHARACTER =====
local function highlightCharacter(character)
    if not character or not character.Parent then return end
    if not highlightingEnabled then return end
    if isLocalPlayerCharacter(character) then return end
    
    local currentHealth, maxHealth = getHealthValues(character)
    if not currentHealth or currentHealth <= 0 then return end
    
    if highlightData[character] then return end
    
    local isPlayer = isPlayerCharacter(character)
    local fillColor = isPlayer and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    local nameColor = isPlayer and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
    
    -- Create highlight
    local highlight = Instance.new("Highlight")
    highlight.Adornee = character
    highlight.FillColor = fillColor
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character
    
    -- Create billboard with health bar
    local billboard, healthBar, healthText, healthContainer = createNameBillboard(character, character.Name, nameColor)
    
    -- Store data
    local data = {
        highlight = highlight,
        billboard = billboard,
        healthBar = healthBar,
        healthText = healthText,
        healthContainer = healthContainer,
        isPlayer = isPlayer,
        healthSource = character:FindFirstChildOfClass("Humanoid")
    }
    
    highlightData[character] = data
    
    -- Update health bar immediately
    updateHealthBar(character)
    
    -- Connect to health changes
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local connections = {}
        
        -- Attribute changed
        table.insert(connections, humanoid:GetAttributeChangedSignal("Health"):Connect(function()
            if highlightingEnabled and character and character.Parent then
                updateHealthBar(character)
            end
        end))
        
        -- Health property changed
        table.insert(connections, humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if highlightingEnabled and character and character.Parent then
                updateHealthBar(character)
            end
        end))
        
        data.healthConnection = connections
    end
    
    return highlight
end

-- ===== SCAN CHARACTERS =====
local function scanCharacters()
    if not highlightingEnabled then return end
    
    local charsFolder = getCharactersFolder()
    if not charsFolder then return end
    
    local seenCharacters = {}
    
    for _, child in ipairs(charsFolder:GetChildren()) do
        if child:IsA("Model") then
            seenCharacters[child] = true
            if not highlightData[child] then
                highlightCharacter(child)
            end
        end
    end
    
    for character, _ in pairs(highlightData) do
        if not seenCharacters[character] or not character.Parent then
            removeHighlight(character)
        end
    end
end

-- ===== AIMBOT FUNCTIONS (NPC ONLY) =====
local function getValidTargets()
    local targets = {}
    local charsFolder = getCharactersFolder()
    if not charsFolder then return targets end
    
    local mouseLocation = UserInputService:GetMouseLocation()
    
    for _, character in ipairs(charsFolder:GetChildren()) do
        if character:IsA("Model") then
            -- Skip self
            if isLocalPlayerCharacter(character) then continue end
            
            -- Skip players (NPC ONLY)
            if isPlayerCharacter(character) then continue end
            
            -- Skip dead
            if not isCharacterAlive(character) then continue end
            
            -- Get head
            local head = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
            if not head then continue end
            
            -- Check if on screen
            local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if not onScreen then continue end
            
            -- Calculate distance from cursor
            local screenPos = Vector2.new(headPos.X, headPos.Y)
            local distanceToCursor = (screenPos - mouseLocation).Magnitude
            
            -- Check FOV
            if distanceToCursor > aimbotFOV then continue end
            
            -- Wall check
            if wallCheck(head.Position, character) then continue end
            
            table.insert(targets, {
                character = character,
                head = head,
                distance = distanceToCursor,
                position = head.Position
            })
        end
    end
    
    -- Sort by distance to cursor
    table.sort(targets, function(a, b)
        return a.distance < b.distance
    end)
    
    return targets
end

local function aimAtTarget(target)
    if not target then return end
    
    local camera = Workspace.CurrentCamera
    local targetPos = target.position
    
    -- Create CFrame looking at target
    local lookAt = CFrame.lookAt(camera.CFrame.Position, targetPos)
    
    -- Smoothly interpolate
    camera.CFrame = camera.CFrame:Lerp(lookAt, aimbotSmoothness)
end

local function startAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then return end
        if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
        
        local targets = getValidTargets()
        if #targets > 0 then
            aimAtTarget(targets[1])
        end
    end)
end

local function stopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
end

-- ===== CLEANUP =====
local function clearAllHighlights()
    for character, _ in pairs(highlightData) do
        removeHighlight(character)
    end
    highlightData = {}
end

-- ===== START HIGHLIGHTING =====
local function startHighlighting()
    if highlightingEnabled then return end
    
    highlightingEnabled = true
    scanCharacters()
    
    local charsFolder = getCharactersFolder()
    if charsFolder then
        if cleanupConnection then
            cleanupConnection:Disconnect()
            cleanupConnection = nil
        end
        
        cleanupConnection = charsFolder.ChildAdded:Connect(function(child)
            if highlightingEnabled and child:IsA("Model") then
                task.wait(0.5)
                highlightCharacter(child)
            end
        end)
    end
    
    if scanConnection then
        scanConnection:Disconnect()
        scanConnection = nil
    end
    
    scanConnection = RunService.Heartbeat:Connect(function()
        if highlightingEnabled then
            scanCharacters()
        end
    end)
    
    Rayfield:Notify({
        Title = "Highlighter",
        Content = "Enabled - NPCs red, Players green, Health bars shown",
        Duration = 3,
    })
end

-- ===== STOP HIGHLIGHTING =====
local function stopHighlighting()
    highlightingEnabled = false
    
    if scanConnection then
        scanConnection:Disconnect()
        scanConnection = nil
    end
    
    if cleanupConnection then
        cleanupConnection:Disconnect()
        cleanupConnection = nil
    end
    
    clearAllHighlights()
    
    Rayfield:Notify({
        Title = "Highlighter",
        Content = "Disabled",
        Duration = 2,
    })
end

