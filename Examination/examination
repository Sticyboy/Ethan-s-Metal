MainTab:CreateSection("NPC Highlighter")

-- Main Toggle
local HighlightToggle = MainTab:CreateToggle({
    Name = "Enable NPC Highlighting",
    CurrentValue = false,
    Flag = "NPCHighlightToggle",
    Callback = function(Value)
        if Value == HighlightingEnabled then return end
        
        HighlightingEnabled = Value
        
        if Value then
            -- Disconnect any existing connections first
            if ChildAddedConnection then
                ChildAddedConnection:Disconnect()
                ChildAddedConnection = nil
            end
            
            -- Start ESP
            processExistingCharacters()
            
            -- Start periodic refresh
            if ESPRefreshConnection then
                ESPRefreshConnection:Disconnect()
            end
            
            ESPRefreshConnection = RunService.Heartbeat:Connect(function()
                -- Keep checking for new characters
                for _, character in pairs(workspace.Characters:GetChildren()) do
                    if character:IsA("Model") and not isPlayerCharacter(character) then
                        if not ActiveHighlights[character] and isAlive(character) then
                            highlightCharacter(character)
                        elseif ActiveHighlights[character] and not isAlive(character) then
                            removeCharacterESP(character)
                        end
                    end
                end
            end)
            
            Rayfield:Notify({
                Title = "NPC Highlighting",
                Content = "NPC highlighting has been enabled",
                Duration = 3,
                Image = 4483362458
            })
        else
            -- Disconnect all connections
            if ChildAddedConnection then
                ChildAddedConnection:Disconnect()
                ChildAddedConnection = nil
            end
            
            if ESPRefreshConnection then
                ESPRefreshConnection:Disconnect()
                ESPRefreshConnection = nil
            end
            
            -- Remove all highlights
            removeAllHighlights()
            
            Rayfield:Notify({
                Title = "NPC Highlighting",
                Content = "NPC highlighting has been disabled",
                Duration = 3,
                Image = 4483362458
            })
        end
    end,
})

