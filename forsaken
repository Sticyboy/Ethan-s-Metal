    highlight.Name = "Generator_Highlight"
    highlight.Parent = generator
    highlight.FillColor = generatorESPColor
    highlight.FillTransparency = 0.7
    highlight.OutlineColor = generatorESPColor
    highlight.OutlineTransparency = 0.6
    table.insert(itemHighlights, highlight) -- Reusing itemHighlights table for simplicity
    
    -- Create billboard for progress
    if generator:FindFirstChild("Progress") then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "Generator_Billboard"
        local parentPart = generator:FindFirstChild("Main") or generator:FindFirstChildWhichIsA("BasePart") or generator
        if parentPart then
            -- Calculate text size based on multiplier
            local adjustedWidth = 100 * espTextSize
            local adjustedHeight = 40 * espTextSize
            
            billboard.Parent = parentPart
            billboard.Size = UDim2.new(0, adjustedWidth, 0, adjustedHeight)
            billboard.StudsOffset = Vector3.new(0, 3 * espTextSize, 0)
            billboard.AlwaysOnTop = true
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Parent = billboard
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = string.format("Generator: %d%%", generator.Progress.Value)
            textLabel.TextColor3 = generatorESPColor
            textLabel.TextStrokeTransparency = 0
            textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextScaled = true
            
            -- Update progress text
            local connection
            connection = generator.Progress.Changed:Connect(function()
                if textLabel and textLabel.Parent then
                    textLabel.Text = string.format("Generator: %d%%", generator.Progress.Value)
                else
                    if connection then
                        connection:Disconnect()
                    end
                end
            end)
            
            table.insert(generatorBillboards, billboard)
        end
    end
