local function addItemESP(item)
    if not item then return end
    
    -- Check if it's actually an item model (has parts)
    local hasParts = false
    for _, part in ipairs(item:GetChildren()) do
        if part:IsA("BasePart") then
            hasParts = true
            break
        end
    end
    
    if not hasParts then return end
    
    -- Add highlight to all parts of the item
    for _, part in ipairs(item:GetChildren()) do
        if part:IsA("BasePart") then
            -- Check if part already has a highlight
            local existingHighlight = part:FindFirstChildOfClass("Highlight")
            if not existingHighlight then
                local highlight = Instance.new("Highlight")
                highlight.Name = "Item_Highlight"
                highlight.Parent = part
                highlight.FillColor = itemESPColor
                highlight.FillTransparency = 0.7
                highlight.OutlineColor = itemESPColor
                highlight.OutlineTransparency = 0.6
                table.insert(itemHighlights, highlight)
            end
        end
    end
    
    -- Add billboard with item name
    local primaryPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
    if primaryPart then
        -- Check if part already has a billboard
        local existingBillboard = primaryPart:FindFirstChild("Item_Billboard")
        if not existingBillboard then
            local billboard = Instance.new("BillboardGui")
            billboard.Name = "Item_Billboard"
            
            -- Calculate text size based on multiplier
            local adjustedWidth = 80 * espTextSize
            local adjustedHeight = 30 * espTextSize
            
            billboard.Parent = primaryPart
            billboard.Size = UDim2.new(0, adjustedWidth, 0, adjustedHeight)
            billboard.StudsOffset = Vector3.new(0, 2 * espTextSize, 0)
            billboard.AlwaysOnTop = true
            billboard.ResetOnSpawn = false
            
            local textLabel = Instance.new("TextLabel")
            textLabel.Parent = billboard
            textLabel.Size = UDim2.new(1, 0, 1, 0)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = item.Name
            textLabel.TextColor3 = itemESPColor
            textLabel.TextStrokeTransparency = 0
            textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
            textLabel.Font = Enum.Font.GothamBold
            textLabel.TextScaled = true
            textLabel.ResetOnSpawn = false
            
            table.insert(generatorBillboards, billboard) -- Reusing generatorBillboards table
        end
    end
end

local function scanForItemsInAllLocations()
    -- Scan Workspace root for dropped items (when survivor drops item)
    for _, itemName in ipairs(Items) do
        local item = Workspace:FindFirstChild(itemName)
        if item and item:IsA("Model") then
            addItemESP(item)
        end
    end
    
    -- Scan Map.Ingame.Map for items (when survivor dies with item)
    local mapFolder = Workspace:FindFirstChild("Map")
    if mapFolder then
        local ingameFolder = mapFolder:FindFirstChild("Ingame")
        if ingameFolder then
            local gameMap = ingameFolder:FindFirstChild("Map")
            if gameMap then
                for _, itemName in ipairs(Items) do
                    for _, obj in ipairs(gameMap:GetChildren()) do
                        if obj:IsA("Model") and obj.Name == itemName then
                            addItemESP(obj)
                        end
                    end
                end
            end
        end
    end
    
    -- Also scan in Players folders in case items are attached to players (rare, but just in case)
    if KillersFolder then
        for _, killer in ipairs(KillersFolder:GetChildren()) do
            for _, itemName in ipairs(Items) do
                local item = killer:FindFirstChild(itemName)
                if item and item:IsA("Model") then
                    addItemESP(item)
                end
            end
        end
    end
    
    if SurvivorsFolder then
        for _, survivor in ipairs(SurvivorsFolder:GetChildren()) do
            for _, itemName in ipairs(Items) do
                local item = survivor:FindFirstChild(itemName)
                if item and item:IsA("Model") then
                    addItemESP(item)
                end
            end
        end
    end
end

local function scanForGenerators()
    -- Find Map folder
    local mapFolder = Workspace:FindFirstChild("Map")
    if not mapFolder then return end
    
    local ingameFolder = mapFolder:FindFirstChild("Ingame")
    if not ingameFolder then return end
    
    local gameMap = ingameFolder:FindFirstChild("Map")
    if not gameMap then return end
    
    -- Scan for generators
    for _, obj in ipairs(gameMap:GetChildren()) do
        if obj.Name == "Generator" then
            addGeneratorESP(obj)
        end
    end
end

local function updateESP()
    clearESP()
    
    if not espEnabled then return end
    
    -- Add ESP for killers
    if KillersFolder then
        for _, killer in ipairs(KillersFolder:GetChildren()) do
            local usernameAttr = killer:GetAttribute("Username")
            if usernameAttr and usernameAttr ~= lp.Name then
                addPlayerESP(killer, killerESPColor, true)
            end
        end
    end
    
    -- Add ESP for survivors
    if SurvivorsFolder then
        for _, survivor in ipairs(SurvivorsFolder:GetChildren()) do
            local usernameAttr = survivor:GetAttribute("Username")
            if usernameAttr and usernameAttr ~= lp.Name then
                addPlayerESP(survivor, survivorESPColor, false)
            end
        end
    end
    
    -- Add ESP for generators
    scanForGenerators()
    
    -- Add ESP for items in all possible locations
    scanForItemsInAllLocations()
end

