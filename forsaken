local function startAimbotForDuration(duration)
    if not aimbotEnabled then return end
    
    -- Check if we already have a target
    if aimbotActive then
        -- If we're already targeting someone, don't start another
        return
    end
    
    local targets = getValidTargets()
    
    if #targets == 0 then 
        return 
    end
    
    local target = targets[1]
    aimbotCurrentTarget = target.obj
    aimbotActive = true
    aimbotTargetCount = aimbotTargetCount + 1
    
    -- Turn on shiftlock (permanent)
    setShiftLock(true)
    
    -- Create sphere for the target (red for aimbot)
    createTargetSphere(aimbotCurrentTarget, Color3.fromRGB(255, 0, 0))
    
    if aimbotActiveTimer then
        task.cancel(aimbotActiveTimer)
        aimbotActiveTimer = nil
    end
    
    aimbotActiveTimer = task.delay(duration, function()
        stopAimbot()
    end)
end

local function updateAimbot()
    if not aimbotEnabled then
        if aimbotConnection then
            aimbotConnection:Disconnect()
            aimbotConnection = nil
        end
        stopAimbot()
        return
    end
    
    if aimbotConnection then return end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled or not aimbotActive or not aimbotCurrentTarget then
            return
        end
        
        local myChar = lp.Character
        if not myChar then return end
        
        local humanoid = aimbotCurrentTarget:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            stopAimbot()
            return
        end
        
        -- Get predicted position using position-based prediction
        local targetPos = getPredictedPosition(aimbotCurrentTarget)
        if not targetPos then
            stopAimbot()
            return
        end
        
        local camera = Camera
        local cameraPos = camera.CFrame.Position
        
        local targetCFrame = CFrame.lookAt(cameraPos, targetPos)
        local currentCFrame = camera.CFrame
        
        local currentLook = currentCFrame.LookVector
        local targetLook = targetCFrame.LookVector
        
        local smoothLook = currentLook:Lerp(targetLook, aimbotSmoothness)
        local newCFrame = CFrame.new(cameraPos, cameraPos + smoothLook)
        
        camera.CFrame = newCFrame
    end)
end

local function createFOVCircle()
    if aimbotFOVCircle then
        pcall(function() aimbotFOVCircle:Destroy() end)
        aimbotFOVCircle = nil
    end
    
    -- Only create FOV circle if both aimbot is enabled AND Use FOV is enabled
    if not aimbotEnabled or not aimbotUseFOV then return end
    
    local circle = Drawing.new("Circle")
    circle.Transparency = 1
    circle.Thickness = 2
    circle.NumSides = 60
    circle.Radius = aimbotFOV
    circle.Color = Color3.fromRGB(255, 255, 255)
    circle.Visible = true
    circle.Filled = false
    circle.Visible = aimbotEnabled and aimbotUseFOV
    
    aimbotFOVCircle = circle
    
    -- Update circle position to center of screen
    local connection
    connection = RunService.RenderStepped:Connect(function()
        if aimbotEnabled and aimbotUseFOV and aimbotFOVCircle then
            local viewportSize = Camera.ViewportSize
            aimbotFOVCircle.Position = Vector2.new(viewportSize.X/2, viewportSize.Y/2)
            aimbotFOVCircle.Radius = aimbotFOV
            aimbotFOVCircle.Visible = true
        elseif aimbotFOVCircle then
            aimbotFOVCircle.Visible = false
        end
    end)
end

-- Input hook
local function setupInputHook()
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        local myTeam, myCharacter = getMyCharacterInfo()
        local isKiller = (myTeam == "Killer")
        local isSurvivor = (myTeam == "Survivor")
        
        -- Check specific survivor types
        local isShedletsky = (myTeam == "Survivor" and myCharacter == "Shedletsky")
        local isChance = (myTeam == "Survivor" and myCharacter == "Chance")
        local isTwoTime = (myTeam == "Survivor" and myCharacter == "TwoTime")
        
        -- Check specific killer types
        local isSlasher = (myTeam == "Killer" and myCharacter == "Slasher")
        local isJohnDoe = (myTeam == "Killer" and myCharacter == "JohnDoe")
        local is1x1x1x1 = (myTeam == "Killer" and myCharacter == "1x1x1x1")
        local isc00lkidd = (myTeam == "Killer" and myCharacter == "c00lkidd")
        local isNoli = (myTeam == "Killer" and myCharacter == "Noli")
        local isGuest1337 = (myTeam == "Survivor" and myCharacter == "Guest1337")
        
        -- Left click for killers (0.65s)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not aimbotEnabled then return end
            if not isKiller then
                return
            end
            startAimbotForDuration(0.65)
        end
        
        -- Keyboard keys
        if input.UserInputType == Enum.UserInputType.Keyboard then
            -- Q key abilities
            if input.KeyCode == Enum.KeyCode.Q then
                -- Normal aimbot abilities
                if aimbotEnabled then
                    -- JohnDoe Q (Corrupt Energy) - 4.5 seconds
                    if isJohnDoe then
                        startAimbotForDuration(4.5)
                    -- Shedletsky Q - 1.1 seconds
                    elseif isShedletsky then
                        startAimbotForDuration(1.1)
                    -- TwoTime Q - 0.4 seconds
                    elseif isTwoTime then
                        startAimbotForDuration(0.4)
                    -- 1x1x1x1 Q - 2.1 seconds
                    elseif is1x1x1x1 then
                        startAimbotForDuration(2.1)
                    -- Noli Q - 4 seconds (normal aimbot, not silent aim)
                    elseif isNoli then
                        startAimbotForDuration(4.0)
                    -- Slasher Q - 0.95 seconds
                    elseif isSlasher then
                        startAimbotForDuration(0.95)
                    end
                end
                
                -- Killer silent aim abilities (c00lkidd Q)
                if killerSilentAimEnabled and isc00lkidd then
                    local target = getNearestSurvivor()
                    if target then
                        useKillerSilentAim(0.1, "CorruptNature", target) -- 0.1 seconds for instant windup
                    else
                        SendNotif("CorruptNature", "No survivors found", 1)
                    end
                end
            end
            
            -- E key abilities
            if input.KeyCode == Enum.KeyCode.E then
                -- Normal aimbot abilities
                if aimbotEnabled then
                    -- Chance E - 1.1 seconds
                    if isChance then
                        startAimbotForDuration(1.1)
                    -- 1x1x1x1 E - 1.2 seconds
                    elseif is1x1x1x1 then
                        startAimbotForDuration(1.2)
                    -- c00lkidd E - 0.8 seconds (normal aimbot)
                    elseif isc00lkidd then
                        startAimbotForDuration(0.8)
                    -- Slasher E - 0.5 seconds
                    elseif isSlasher then
                        startAimbotForDuration(0.5)
                    end
                end
                
                -- Killer silent aim abilities (Noli E)
                if killerSilentAimEnabled and isNoli then
                    local target = getNearestSurvivor()
                    if target then
                        useKillerSilentAim(0.8, "Nova", target) -- 0.8 seconds for 0.7s windup
                    else
                        SendNotif("Nova", "No survivors found", 1)
                    end
                end
            end
            
            -- R key for Guest1337 (0.95s)
            if input.KeyCode == Enum.KeyCode.R then
                if not aimbotEnabled then return end
                if not isGuest1337 then
                    return
                end
                startAimbotForDuration(0.95)
            end
        end
    end)
end

