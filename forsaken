    -- Determine target folder (opposite team)
    local targetFolder = nil
    if myTeam == "Killer" then
        targetFolder = SurvivorsFolder
    elseif myTeam == "Survivor" then
        targetFolder = KillersFolder
    else
        -- If we can't determine team, target everyone in both folders
        return getValidTargetsFromBothFolders()
    end
    
    if not targetFolder then return targets end
    
    local viewportSize = Camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X/2, viewportSize.Y/2)
    
    for _, obj in ipairs(targetFolder:GetChildren()) do
        -- Skip self
        local usernameAttr = obj:GetAttribute("Username")
        if usernameAttr and usernameAttr == lp.Name then
            -- Skip this iteration
        else
            -- Check if alive
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Get target part
                local targetPart = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or obj:FindFirstChild("Torso")
                if targetPart then
                    -- Distance check
                    local distance = (targetPart.Position - myRoot.Position).Magnitude
                    if distance <= aimbotMaxDistance then
                        -- Screen position check (only if using FOV)
                        if aimbotUseFOV then
                            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                            if onScreen then
                                local screenVector = Vector2.new(screenPos.X, screenPos.Y)
                                local distanceFromCenter = (screenVector - screenCenter).Magnitude
                                
                                if distanceFromCenter <= aimbotFOV then
                                    table.insert(targets, {
                                        obj = obj,
                                        part = targetPart,
                                        distance = distance,
                                        screenDistance = distanceFromCenter
                                    })
                                end
                            end
                        else
                            -- If not using FOV, just add all valid targets within distance
                            table.insert(targets, {
                                obj = obj,
                                part = targetPart,
                                distance = distance,
                                screenDistance = 0
                            })
                        end
                    end
                end
            end
        end
    end
    
    if aimbotUseFOV then
        -- Sort by screen distance (closest to center)
        table.sort(targets, function(a, b)
            return a.screenDistance < b.screenDistance
        end)
    else
        -- Sort by actual distance (nearest)
        table.sort(targets, function(a, b)
            return a.distance < b.distance
        end)
    end
    
    return targets
end

