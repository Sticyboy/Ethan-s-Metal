-- Set up ESP update listeners
local function setupESPListeners()
    if KillersFolder then
        KillersFolder.ChildAdded:Connect(function(child)
            if espEnabled then
                task.wait(0.1)
                local usernameAttr = child:GetAttribute("Username")
                if usernameAttr and usernameAttr ~= lp.Name then
                    addPlayerESP(child, killerESPColor, true)
                end
            end
        end)
        
        KillersFolder.ChildRemoved:Connect(function(child)
            if espEnabled then
                clearESP()
                updateESP()
            end
        end)
    end
    
    if SurvivorsFolder then
        SurvivorsFolder.ChildAdded:Connect(function(child)
            if espEnabled then
                task.wait(0.1)
                local usernameAttr = child:GetAttribute("Username")
                if usernameAttr and usernameAttr ~= lp.Name then
                    addPlayerESP(child, survivorESPColor, false)
                end
            end
        end)
        
        SurvivorsFolder.ChildRemoved:Connect(function(child)
            if espEnabled then
                clearESP()
                updateESP()
            end
        end)
    end
    
    -- Listen for map changes (for generators)
    Workspace.ChildAdded:Connect(function(child)
        if child.Name == "Map" and espEnabled then
            task.wait(0.5)
            scanForGenerators()
        end
    end)
    
    -- Listen for items being dropped or moved in Workspace root
    Workspace.ChildAdded:Connect(function(child)
        if espEnabled then
            for _, itemName in ipairs(Items) do
                if child.Name == itemName and child:IsA("Model") then
                    task.wait(0.1)
                    addItemESP(child)
                    break
                end
            end
        end
    end)
    
    -- Listen for items in Map.Ingame.Map
    local function watchMapFolder()
        local mapFolder = Workspace:FindFirstChild("Map")
        if mapFolder then
            mapFolder.ChildAdded:Connect(function(child)
                if child.Name == "Ingame" and espEnabled then
                    task.wait(0.5)
                    scanForGenerators()
                    
                    -- Also check for items in the new Ingame
                    task.wait(0.1)
                    scanForItemsInAllLocations()
                end
            end)
            
            local ingameFolder = mapFolder:FindFirstChild("Ingame")
            if ingameFolder then
                ingameFolder.ChildAdded:Connect(function(child)
                    if child.Name == "Map" and espEnabled then
                        task.wait(0.5)
                        scanForGenerators()
                    end
                end)
                
                -- Watch for items being added to Map.Ingame.Map
                local gameMap = ingameFolder:FindFirstChild("Map")
                if gameMap then
                    gameMap.ChildAdded:Connect(function(child)
                        if espEnabled then
                            for _, itemName in ipairs(Items) do
                                if child.Name == itemName and child:IsA("Model") then
                                    task.wait(0.1)
                                    addItemESP(child)
                                    break
                                end
                            end
                        end
                    end)
                end
            end
        end
    end
    
    watchMapFolder()
    
    -- Watch for items being dropped from players
    local function watchPlayerItems(folder)
        folder.ChildAdded:Connect(function(player)
            if espEnabled then
                -- Watch for items being added to player
                player.ChildAdded:Connect(function(child)
                    if espEnabled then
                        for _, itemName in ipairs(Items) do
                            if child.Name == itemName and child:IsA("Model") then
                                task.wait(0.1)
                                addItemESP(child)
                                break
                            end
                        end
                    end
                end)
            end
        end)
    end
    
    if KillersFolder then
        watchPlayerItems(KillersFolder)
    end
    
    if SurvivorsFolder then
        watchPlayerItems(SurvivorsFolder)
    end
end

