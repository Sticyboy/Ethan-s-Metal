local function addPlayerESP(object, color, isKiller)
    if not object then return end
    
    local humanoid = object:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local head = object:FindFirstChild("Head")
    if not head then return end
    
    -- Add highlight (will be toggled based on health)
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Parent = object
    highlight.FillColor = color
    highlight.FillTransparency = 0.7
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0.6
    -- Initially visible if health > 0
    highlight.Enabled = humanoid.Health > 0
    table.insert(espHighlights, highlight)
    
    -- Calculate text size based on multiplier
    local baseWidth = 150
    local baseHeight = 80
    local adjustedWidth = baseWidth * espTextSize
    local adjustedHeight = baseHeight * espTextSize
    
    -- Create main BillboardGui for all text
    local mainGui = Instance.new("BillboardGui")
    mainGui.Name = "ESP_Main"
    mainGui.Parent = head
    mainGui.Size = UDim2.new(0, adjustedWidth, 0, adjustedHeight)
    mainGui.StudsOffset = Vector3.new(0, 3 * espTextSize, 0)
    mainGui.AlwaysOnTop = true
    -- Text only visible if health > 0
    mainGui.Enabled = humanoid.Health > 0
    
    -- Get username from attribute
    local username = object:GetAttribute("Username") or object.Name
    
    -- Username label (top)
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = mainGui
    nameLabel.Size = UDim2.new(1, 0, 0.4, 0)
    nameLabel.Position = UDim2.new(0, 0, 0, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = username
    nameLabel.TextColor3 = color
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextScaled = true
    
    -- Character name label (middle)
    local charLabel = Instance.new("TextLabel")
    charLabel.Parent = mainGui
    charLabel.Size = UDim2.new(1, 0, 0.3, 0)
    charLabel.Position = UDim2.new(0, 0, 0.4, 0)
    charLabel.BackgroundTransparency = 1
    charLabel.Text = object.Name
    charLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    charLabel.TextStrokeTransparency = 0
    charLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    charLabel.Font = Enum.Font.Gotham
    charLabel.TextScaled = true
    
    -- Health text label (bottom)
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Parent = mainGui
    healthLabel.Size = UDim2.new(1, 0, 0.3, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.7, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.Text = string.format("HP: %.0f/%.0f", humanoid.Health, humanoid.MaxHealth)
    healthLabel.TextColor3 = isKiller and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(100, 255, 100)
    healthLabel.TextStrokeTransparency = 0
    healthLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    healthLabel.Font = Enum.Font.GothamBold
    healthLabel.TextScaled = true
    
    -- Update health text and visibility when health changes
    local connection
    connection = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if healthLabel and healthLabel.Parent then
            healthLabel.Text = string.format("HP: %.0f/%.0f", humanoid.Health, humanoid.MaxHealth)
            
            -- Toggle highlight and billboard based on health
            if highlight and highlight.Parent then
                highlight.Enabled = humanoid.Health > 0
            end
            if mainGui and mainGui.Parent then
                mainGui.Enabled = humanoid.Health > 0
            end
        else
            if connection then
                connection:Disconnect()
            end
        end
    end)
    
    table.insert(espBillboards, mainGui)
end

