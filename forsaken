local function startItemScanning()
    if itemScanConnection then
        itemScanConnection:Disconnect()
    end
    
    itemScanConnection = RunService.Heartbeat:Connect(function()
        if espEnabled then
            -- Only scan occasionally to avoid performance issues
            if tick() % 2 < 0.1 then -- Scan every ~2 seconds
                scanForItemsInAllLocations()
            end
        end
    end)
end

