            SendNotif("Nova", "Cooldown: " .. remaining .. "s remaining", 1)
            return false
        end
        lastNovaTime = now
    end
    
    currentTarget = target
    silentAimActive = true
    killerSilentAimActive = true
    
    -- Create prediction sphere for the target (purple for killer silent aim)
    createTargetSphere(target, Color3.fromRGB(255, 0, 255)) -- Purple
    
    local success = false
    if abilityName == "CorruptNature" then
        success = fireCorruptNature()
    elseif abilityName == "Nova" then
        success = fireNova()
    end
    
    if success then
        SendNotif(abilityName, "Firing at " .. target.Name, duration)
        
        if killerSilentAimTimer then
            task.cancel(killerSilentAimTimer)
        end
        
        killerSilentAimTimer = task.delay(duration, function()
            stopKillerSilentAim()
        end)
        
        return true
    else
